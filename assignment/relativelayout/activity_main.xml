<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DCE7F6"
    android:padding="24dp"
    tools:context=".MainActivity">

    <View
        android:id="@+id/topDot"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_centerHorizontal="true"
        android:background="#111827" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/topDot"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="14dp"
        android:text="@string/app_name"
        android:textColor="#143B6B"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvTitle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:text="@string/login_subtitle"
        android:textColor="#40658E"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvEmailLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvSubtitle"
        android:layout_marginTop="44dp"
        android:text="@string/email_label"
        android:textColor="#123A67"
        android:textSize="12sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvEmailLabel"
        android:backgroundTint="#BAC8D8"
        android:hint="@string/email_hint"
        android:inputType="textEmailAddress"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:textColor="#0F172A"
        android:textColorHint="#93A4B8" />

    <TextView
        android:id="@+id/tvPasswordLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/etEmail"
        android:layout_marginTop="26dp"
        android:text="@string/password_label"
        android:textColor="#123A67"
        android:textSize="12sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvPasswordLabel"
        android:backgroundTint="#BAC8D8"
        android:hint="@string/password_hint"
        android:inputType="textPassword"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:textColor="#0F172A"
        android:textColorHint="#93A4B8" />

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/etPassword"
        android:layout_marginTop="34dp"
        android:backgroundTint="#1E63BF"
        android:text="@string/login_button"
        android:textAllCaps="false"
        android:textColor="#FFFFFF" />

    <TextView
        android:id="@+id/tvForgotPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/btnLogin"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="16dp"
        android:text="@string/forgot_password"
        android:textColor="#1A5CBD"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvRegister"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvForgotPassword"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="22dp"
        android:text="@string/register_prompt"
        android:textColor="#1A5CBD"
        android:textSize="12sp" />

</RelativeLayout>

